import random
import numpy as np

actions = ["Left", "Right"]

for  episode in range(5):
  state = random.randint(0,1)
  action = random.choice(actions)
  if state  == 0 and action == "Left":
    reward = 10
  elif state == 1 and action == "Right":
    reward = 10
  else:
    reward = -10

  print(f"State :{state}")
  print(f"Action :{action}")
  print(f"Reward :{reward}")
