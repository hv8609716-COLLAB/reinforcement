
import numpy as np


actions = ["left", "right"]
policy = [0.5, 0.5]
for episode in range(5):
  action = np.random.choice(actions, p=policy)
  print("Choosen Action: ", action)

  if action == "right":
    reward = 1
  else:
    reward = -1

  if reward == 1:
    policy[1] += 0.1
    policy[0] -= 0.1
  else:
    policy[1] -= 0.1
    policy[0] += 0.1

  policy = np.clip(policy, 0.1, 0.9)
  print(policy)
